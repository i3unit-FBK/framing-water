# Normalize text files by default and keep LF in repository
* text=auto eol=lf

# Source and config files
*.ino  text eol=lf
*.c    text eol=lf
*.cpp  text eol=lf
*.h    text eol=lf
*.hpp  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.sh   text eol=lf
*.ps1  text eol=crlf

# Common scripts on Windows
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.bmp  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.7z   binary
*.gz   binary
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary

# Lock files (keep as text, normalized)
*.lock text eol=lf